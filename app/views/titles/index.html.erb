<h1>Titles</h1>

<div class="filters">
  <%= form_with url: titles_path, method: :get, local: true do %>
    <div class="filter-group">
      <%= label_tag :title_type, "Type *" %>
      <%= select_tag :title_type,
          options_for_select([["Select type...", ""]] + @title_types.map { |t| [t.titleize, t] }, @title_type),
          required: true %>
    </div>

    <div class="filter-group">
      <%= label_tag :start_year, "Start Year *" %>
      <%= number_field_tag :start_year, @start_year,
          min: 1900,
          max: Date.current.year + 5,
          required: true,
          placeholder: "e.g. 2020" %>
    </div>

    <div class="filter-group">
      <%= label_tag :end_year, "End Year *" %>
      <%= number_field_tag :end_year, @end_year,
          min: 1900,
          max: Date.current.year + 5,
          required: true,
          placeholder: "e.g. 2024" %>
    </div>

    <div class="filter-group">
      <%= label_tag :min_rating, "Min IMDB Rating" %>
      <%= number_field_tag :min_rating, @min_rating,
          min: 0,
          max: 10,
          step: 0.1,
          placeholder: "e.g. 7.0" %>
    </div>

    <div class="filter-group">
      <%= label_tag :min_votes, "Min Votes" %>
      <%= number_field_tag :min_votes, @min_votes,
          min: 0,
          placeholder: "e.g. 10000" %>
    </div>

    <div class="filter-group filter-checkboxes">
      <div>
        <%= label_tag :show_in_french_theaters, "Show in French Theaters" %>
        <%= select_tag :show_in_french_theaters, options_for_select([["No", "no"], ["Yes", "yes"], ["Only", "only"]], @show_in_french_theaters) %>
      </div>
      <div>
        <%= label_tag :show_in_italian_theaters, "Show in Italian Theaters" %>
        <%= select_tag :show_in_italian_theaters, options_for_select([["No", "no"], ["Yes", "yes"], ["Only", "only"]], @show_in_italian_theaters) %>
      </div>
      <div>
        <%= label_tag :show_at_home, "Show at Home" %>
        <%= select_tag :show_at_home, options_for_select([["No", "no"], ["Yes", "yes"], ["Only", "only"]], @show_at_home) %>
      </div>
      <div>
        <%= label_tag :show_in_plex, "Show in Plex" %>
        <%= select_tag :show_in_plex, options_for_select([["No", "no"], ["Yes", "yes"], ["Only", "only"]], @show_in_plex) %>
      </div>
      <div>
        <%= label_tag :show_already_watched, "Show Already Watched" %>
        <%= select_tag :show_already_watched, options_for_select([["No", "no"], ["Yes", "yes"], ["Only", "only"]], @show_already_watched) %>
      </div>
      <div>
        <%= label_tag :show_wip, "Show WIP" %>
        <%= select_tag :show_wip, options_for_select([["No", "no"], ["Yes", "yes"], ["Only", "only"]], @show_wip) %>
      </div>
      <div>
        <%= label_tag :show_with_preferences, "Show with Preferences" %>
        <%= select_tag :show_with_preferences, options_for_select([["No", "no"], ["Yes", "yes"], ["Only", "only"]], @show_with_preferences) %>
      </div>
    </div>

    <button type="submit">Search</button>
  <% end %>
</div>

<% if @error.present? %>
  <div class="error"><%= @error %></div>
<% elsif @start_year.nil? && @title_type.nil? %>
  <div class="info">
    Select a type and year range to view titles. Maximum range is <%= TitlesController::MAX_YEAR_RANGE %> years.
  </div>
<% elsif @titles.any? %>
  <p class="results-count">
    Showing <%= @titles.size %> titles
    <% if @titles.size == 500 %>
      (limited to 500 results)
    <% end %>
  </p>

  <table>
    <thead>
      <tr>
        <th><%= sort_link("Title", "original_title") %></th>
        <th><%= sort_link("Year", "start_year") %></th>
        <th><%= sort_link("IMDB Rating", "average_rating") %></th>
        <th><%= sort_link("in French Theaters", "theater_air_date_fr") %></th>
        <th><%= sort_link("in Italian Theaters", "theater_air_date_it") %></th>
        <th><%= sort_link("at Home", "home_air_date") %></th>
        <th><%= sort_link("in Plex", "in_plex") %></th>
        <th>Languages</th>
        <th>My Preferences</th>
      </tr>
    </thead>
    <tbody>
      <% @titles.each do |title| %>
        <tr>
          <td><%= link_to title.original_title, "https://www.imdb.com/title/#{title.tconst}", target: "_blank" %></td>
          <td><%= title.start_year %></td>
          <td><%= title.average_rating ? "#{title.average_rating} (#{number_with_delimiter(title.num_votes)})" : "" %></td>
          <td><%= title.theater_air_date_fr %></td>
          <td><%= title.theater_air_date_it %></td>
          <td><%= title.home_air_date %></td>
          <td><%= title.in_plex ? "✓" : "" %></td>
          <td><%= title.languages %></td>
          <td><%= @preferences_by_tconst[title.tconst] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="info">No titles found for the selected criteria.</div>
<% end %>
