# Copy this file to .env and fill in your values
# cp .env.example .env

# Database connection (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/prompter_development

# Redis connection (for Sidekiq)
REDIS_URL=redis://localhost:6379/1

# TMDB API key (get one at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Plex configuration (choose ONE method)
#
# Option 1: Plex API (recommended for remote servers)
# Get your token: Open Plex Web > any item > Get Info > View XML > look for X-Plex-Token in URL
PLEX_URL=http://your-plex-server:32400
PLEX_TOKEN=

# Option 2: Direct database access (for local Plex or mounted database)
# PLEX_DB_PATH=/path/to/com.plexapp.plugins.library.db

# IMDb personal data scraping (optional)
# Your IMDb user ID (found in your profile URL)
IMDB_USER_ID=ur36872000

# IMDb authentication cookies (required for ratings export)
# Get these from your browser's developer tools after logging into IMDb
IMDB_UBID_COOKIE=
IMDB_AT_COOKIE=

# IMDb list URLs (optional, defaults are provided)
# IMDB_ACTORS_LIST_URL=https://www.imdb.com/list/ls561367354
# IMDB_WRITERS_LIST_URL=https://www.imdb.com/list/ls561367143
# IMDB_DIRECTORS_LIST_URL=https://www.imdb.com/list/ls561367616
# IMDB_BLACKLIST_URL=https://www.imdb.com/list/ls561616843
